# =============================================================================
# Radiante v2 - Configuracao de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA versionar o .env real.
# =============================================================================

# --- AWS ---
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SESSION_TOKEN=  # Opcional - apenas se usar temp credentials via STS
REGION=us-east-1

# --- Amazon Bedrock ---
AWS_BEARER_TOKEN_BEDROCK=ABSKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# --- Precos Grok (opcional - apenas se usar modelo Grok) ---
GROK_PRICE_INPUT=0.00000125
GROK_PRICE_OUTPUT=0.00000250
GROK_PRICE_CACHE_READ=0.00000020
GROK_REASONING_EFFORT=high

# --- AWS Account (informativo) ---
AWS_ACCOUNT_ID=123456789012
